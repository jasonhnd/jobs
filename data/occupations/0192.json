  "tasks_lead_ja": "電車や電気機関車を運転し、ダイヤにしたがって、旅客や貨物を安全、正確に輸送する。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "運行計画に基づき、乗務前に各種の連絡事項を確認してから担当する電車に乗務する。",
      "execution_rate": 0.98,
      "importance": 4.62
    },
    {
      "task_id": 2,
      "description_ja": "運転前に、機器類の点検、安全装置のチェックをする。",
      "execution_rate": 0.98,
      "importance": 4.52
    },
    {
      "task_id": 3,
      "description_ja": "各種表示灯の点灯、信号標識灯を確認したうえで、電車を発車させる。",
      "execution_rate": 0.98,
      "importance": 4.64
    },
    {
      "task_id": 4,
      "description_ja": "駅のホームの停止目標に合わせて停車する。",
      "execution_rate": 0.98,
      "importance": 4.5
    },
    {
      "task_id": 5,
      "description_ja": "扉が完全に閉まったかどうかを確認してから発車させる。",
      "execution_rate": 0.961,
      "importance": 4.673
    },
    {
      "task_id": 6,
      "description_ja": "路線の状況に応じて速度を調節し、信号機、標識、線路の状況に注意しながら、ダイヤにしたがって運転する。",
      "execution_rate": 0.98,
      "importance": 4.54
    },
    {
      "task_id": 7,
      "description_ja": "安全な運行を心がけ、必要に応じて警笛を鳴らす。",
      "execution_rate": 0.98,
      "importance": 4.4
    },
    {
      "task_id": 8,
      "description_ja": "事故などの緊急時には、非常装置を作動させ、安全を確保するべく対応する。",
      "execution_rate": 0.98,
      "importance": 4.68
    },
    {
      "task_id": 9,
      "description_ja": "脱線や線路の不具合を発見したときは、列車防護無線やスイッチを操作して他の列車を止める。",
      "execution_rate": 0.98,
      "importance": 4.64
    },
    {
      "task_id": 10,
      "description_ja": "車両が運転中に故障したときには、マニュアルにより適切に対処する。",
      "execution_rate": 0.98,
      "importance": 4.36
    },
    {
      "task_id": 11,
      "description_ja": "旅客の忘れ物や急病に対応する。",
      "execution_rate": 0.98,
      "importance": 3.96
    },
    {
      "task_id": 12,
      "description_ja": "車両の入庫の際は、各種の計器やスイッチ類を点検し、運転状況を報告する。",
      "execution_rate": 0.98,
      "importance": 4.34
    },
    {
      "task_id": 13,
      "description_ja": "乗務終了後に運転した列車の運転状況や車両状態を担当上司に報告する。",
      "execution_rate": 0.961,
      "importance": 4.286
    },
    {
      "task_id": 14,
      "description_ja": "貨物列車を運転する場合には、連結された貨車の重さに応じた運転をする。",
      "execution_rate": 0.549,
      "importance": 4.464
    },
    {
      "task_id": 15,
      "description_ja": "列車の連結や分割を行う。",
      "execution_rate": 0.569,
      "importance": 4.069
    },
    {
      "task_id": 16,
      "description_ja": "ワンマン路線区間で、車内放送や車内の温度調節を行う。",
      "execution_rate": 0.686,
      "importance": 3.686
    }
  ],
