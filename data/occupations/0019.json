  "tasks_lead_ja": "プラスチックに熱を加えて成形機で成形し、さまざまな製品を作る。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "試作品を作るためにプラスチック材料を選定する。",
      "execution_rate": 0.729,
      "importance": 3.143
    },
    {
      "task_id": 2,
      "description_ja": "試作品を制作し、不具合を調べて量産できるように条件を検討する。",
      "execution_rate": 0.792,
      "importance": 3.316
    },
    {
      "task_id": 3,
      "description_ja": "成形機のプレスベッドに金型やその他の装備品を置いて固定し、接続ラインを取り付ける。",
      "execution_rate": 0.729,
      "importance": 3.0
    },
    {
      "task_id": 4,
      "description_ja": "打ち抜き型を機械に取り付けるか、打ち抜き皮を圧縮して離型剤で覆う。",
      "execution_rate": 0.563,
      "importance": 2.926
    },
    {
      "task_id": 5,
      "description_ja": "温度や圧力、溶けた材料の射出速度などの成形条件を決定するために仕様書を確認する。",
      "execution_rate": 0.792,
      "importance": 3.368
    },
    {
      "task_id": 6,
      "description_ja": "成形条件を成形機にセットし、仕様どおりに製造できるように試運転して調節する。",
      "execution_rate": 0.813,
      "importance": 3.436
    },
    {
      "task_id": 7,
      "description_ja": "処方に従って、へらと混合装置を使用して、触媒、熱可塑材料、着色料を混合する。",
      "execution_rate": 0.542,
      "importance": 2.769
    },
    {
      "task_id": 8,
      "description_ja": "連続運転の成形機に材料を補充する。",
      "execution_rate": 0.833,
      "importance": 3.1
    },
    {
      "task_id": 9,
      "description_ja": "製品の成形を行う機械を操作し、機械の運転状態を監視して調整する。",
      "execution_rate": 0.833,
      "importance": 2.95
    },
    {
      "task_id": 10,
      "description_ja": "手動工具とエアホースを使用して、打ち抜き型や金型から加工品を取り外す。",
      "execution_rate": 0.646,
      "importance": 2.677
    },
    {
      "task_id": 11,
      "description_ja": "製品の表面や寸法の欠陥を計測器を使用して測定する。",
      "execution_rate": 0.833,
      "importance": 3.2
    },
    {
      "task_id": 12,
      "description_ja": "ナイフを使用して部品から余分な材料を取り除く。",
      "execution_rate": 0.625,
      "importance": 2.767
    },
    {
