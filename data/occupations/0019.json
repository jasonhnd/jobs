      "execution_rate": 0.688,
      "importance": 2.576
    },
    {
      "task_id": 15,
      "description_ja": "成形用ロボットのプログラムを作成する。",
      "execution_rate": 0.604,
      "importance": 2.828
    },
    {
      "task_id": 16,
      "description_ja": "機械と付属装置を保守、点検する。",
