  "tasks_lead_ja": "原料肉を分割・整形した後、塩づけ、くん煙などの加工をして、ハム、ベーコン、ソーセージを製造する。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "原料となる枝肉をナイフで部位ごとに切りはなし、骨を抜き、脂肪やすじを除去し整形する。",
      "execution_rate": 0.7,
      "importance": 3.464
    },
    {
      "task_id": 2,
      "description_ja": "ピックル液に肉を漬けたり、注入機で原料肉の中にピックルを自動的に注入して塩せきする。",
      "execution_rate": 0.7,
      "importance": 3.464
    },
    {
      "task_id": 3,
      "description_ja": "一定期間冷蔵庫で寝かせた後、ケーシングに詰める装置を操作する。",
      "execution_rate": 0.725,
      "importance": 3.345
    },
    {
      "task_id": 4,
      "description_ja": "ハムの中間品を乾燥し、スモークハウスでくん煙する。",
      "execution_rate": 0.775,
      "importance": 3.71
