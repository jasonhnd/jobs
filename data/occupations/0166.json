  "tasks_lead_ja": "歯科医師の指導の下に、歯や歯茎の病気の予防処置、医師の診療の補助、歯科保健指導などを行う。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "歯科診療所で、受付や精算、診療報酬の請求事務をする。",
      "execution_rate": 0.789,
      "importance": 3.268
    },
    {
      "task_id": 2,
      "description_ja": "患者に診療前の簡単な問診をする。",
      "execution_rate": 0.962,
      "importance": 3.7
    },
    {
      "task_id": 3,
      "description_ja": "歯科器具を使用し、歯や歯茎周辺の歯石、付着物、汚れを除去する。",
      "execution_rate": 0.962,
      "importance": 4.22
    },
    {
      "task_id": 4,
      "description_ja": "薬剤を用い、歯茎のくぼみや歯周病の徴候をチェックする。",
      "execution_rate": 0.731,
      "importance": 3.579
    },
    {
      "task_id": 5,
