  "tasks_lead_ja": "眼鏡店に来店したお客の視力を測定し、お客に合った商品の選定・加工をする。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "店頭に商品を陳列する。",
      "execution_rate": 0.947,
      "importance": 3.519
    },
    {
      "task_id": 2,
      "description_ja": "視力・視野などについて、客からの相談を受け、説明する。",
      "execution_rate": 1.0,
      "importance": 3.86
    },
    {
      "task_id": 3,
      "description_ja": "お客が使用している現行レンズの種類を調べるために、レンズ測定計、レンズ分析器を操作する。",
      "execution_rate": 0.93,
      "importance": 3.792
    },
    {
      "task_id": 4,
      "description_ja": "お客の視力を測定するために、通常の視力検査を行ったり、オートレフラクトメーター（眼の屈折度を測定する装置）を操作する。",
      "execution_rate": 0.965,
      "importance": 4.145
    },
    {
      "task_id": 5,
      "description_ja": "お客のサイズ（鼻梁、眼のサイズ、こめかみの長さ、頭位、瞳孔間距離、視覚的中心線など）を測るために、測定機器を操作する。",
      "execution_rate": 0.895,
      "importance": 3.843
    },
