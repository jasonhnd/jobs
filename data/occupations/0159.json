  "tasks_lead_ja": "虫歯など歯の疾患の治療や予防指導、歯列の矯正などを行う。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "患者の話を聞き、歯科用視鏡やＸ線写真などを用いて、歯の状態を診察し、治療方針を決める。",
      "execution_rate": 0.966,
      "importance": 4.446
    },
    {
      "task_id": 2,
      "description_ja": "虫歯となった歯の患部を削り、専用の材料を充填したり、金属をかぶせるなどして、患部を覆う。",
      "execution_rate": 0.966,
      "importance": 4.286
    },
    {
      "task_id": 3,
      "description_ja": "抜歯を行い、義歯や入れ歯を患部に装着する。",
      "execution_rate": 0.966,
      "importance": 4.232
    },
    {
      "task_id": 4,
