  "tasks_lead_ja": "建築物の開口部に金属製の窓や扉などを取付ける作業をする。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "家の外壁を手動工具と動力工具を使用して切断し、開口部を作る。（追加的に取付ける場合）",
      "execution_rate": 0.617,
      "importance": 2.448
    },
    {
      "task_id": 2,
      "description_ja": "巻尺、型板、マーカーを使用して、開口部の寸法を測定し、サッシの取り付け位置に印をつける。",
      "execution_rate": 0.936,
      "importance": 3.318
    },
    {
      "task_id": 3,
      "description_ja": "サッシ枠を仮に位置決めし、取り付け位置を微調整して決定する。",
      "execution_rate": 0.957,
      "importance": 3.667
    },
    {
      "task_id": 4,
      "description_ja": "コンクリート壁に埋め込まれた鉄筋とサッシ枠の溶接用アンカーを電気溶接して固定する。",
      "execution_rate": 0.723,
      "importance": 3.412
    },
    {
      "task_id": 5,
      "description_ja": "サッシ枠とコンクリート面の隙間にモルタルを詰め込んでふさぐ。",
      "execution_rate": 0.489,
      "importance": 2.957
    },
    {
      "task_id": 6,
      "description_ja": "ガラスや金物などを取り付け、動きを調整する。",
      "execution_rate": 0.957,
      "importance": 3.733
    },
    {
      "task_id": 7,
      "description_ja": "所定の指示に従って、仕事台の上または組立てジグに資材を並べる。",
      "execution_rate": 0.787,
      "importance": 2.892
    },
    {
      "task_id": 8,
      "description_ja": "サッシの欠陥や故障を修理、交換する。",
      "execution_rate": 0.957,
      "importance": 3.6
    },
    {
      "task_id": 9,
      "description_ja": "ひび、継ぎ目、陥没、釘穴に詰め物を詰める。",
      "execution_rate": 0.617,
      "importance": 2.517
    },
    {
