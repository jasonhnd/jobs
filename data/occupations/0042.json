  "tasks_lead_ja": "新築や改装・改築工事の際に、建物の室内の床、壁、天井などの表面をシート、壁紙、カーペットなどで整える。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "工事の見積書を作成する。",
      "execution_rate": 0.691,
      "importance": 3.759
    },
    {
      "task_id": 2,
      "description_ja": "使用する材料の品番を決定する。",
      "execution_rate": 0.738,
      "importance": 3.742
    },
    {
      "task_id": 3,
      "description_ja": "作業をするために足場を組む。",
      "execution_rate": 0.667,
      "importance": 2.893
    },
    {
      "task_id": 4,
      "description_ja": "水、蒸気機械、化学除去剤、スクレーパーを使用して、古い壁紙を除去する。",
      "execution_rate": 0.714,
      "importance": 3.167
    },
    {
      "task_id": 5,
      "description_ja": "壁と天井の穴やひびをしっくいで埋めたり、紙やすりを使用して凹凸を滑らかにする。",
      "execution_rate": 0.762,
      "importance": 3.469
    },
    {
      "task_id": 6,
      "description_ja": "ペイント除去剤とソーダ液を使用して、塗装、ニス、油を除去し、下地をととのえる。",
      "execution_rate": 0.429,
      "importance": 2.611
    },
    {
      "task_id": 7,
      "description_ja": "ナイフを使用して、天井や幅木の余分な材料を取り除き、平らにする。",
      "execution_rate": 0.643,
      "importance": 3.259
    },
    {
      "task_id": 8,
      "description_ja": "下げ振りと白墨線を使用して、壁に垂直線をつける。",
      "execution_rate": 0.714,
      "importance": 3.233
    },
    {
      "task_id": 9,
      "description_ja": "表面を覆うのに必要な布や壁紙片の数と長さを計算するために、壁と天井を測る。",
      "execution_rate": 0.738,
      "importance": 3.516
    },
    {
      "task_id": 10,
      "description_ja": "大ばさみやかみそりを使用して、ロールから壁紙や布を測って適切な大きさに切り取る。",
      "execution_rate": 0.691,
      "importance": 3.345
    },
    {
      "task_id": 11,
      "description_ja": "布や壁紙を揃えて置いて、隣り合った端を合わせる。",
      "execution_rate": 0.714,
      "importance": 3.633
    },
    {
      "task_id": 12,
      "description_ja": "壁や天井に塗る接着剤を作るために、クロス原液のりを水で薄め撹拌する。",
      "execution_rate": 0.667,
      "importance": 3.393
    },
    {
      "task_id": 13,
      "description_ja": "はけ、ローラー、ペースティング機を使用して、壁や天井に接着剤を薄く塗る。",
      "execution_rate": 0.571,
      "importance": 3.042
    },
    {
      "task_id": 14,
      "description_ja": "機械を使ってクロスに糊付けし、壁に張って、へらとカッターを使って余分な部分を切り取る。",
      "execution_rate": 0.691,
      "importance": 3.759
    },
    {
      "task_id": 15,
      "description_ja": "しわや泡を取り除き、接合部を滑らかにするために、ブラシやローラーで接合部をなでつける。",
      "execution_rate": 0.714,
      "importance": 3.867
    },
    {
      "task_id": 16,
      "description_ja": "左官や大工が仕上げた床に基準線を引き、タイルやシートを張ったり、カーペットを敷き込む。",
      "execution_rate": 0.619,
      "importance": 3.538
    },
    {
      "task_id": 17,
      "description_ja": "カーペットの張り込みをするためにキッカーなどの専用工具を使う。",
      "execution_rate": 0.643,
      "importance": 3.519
    },
    {
      "task_id": 18,
      "description_ja": "くし籠手を使い、床に接着剤を塗布し、クッションフロアの張り込みをする。",
      "execution_rate": 0.643,
      "importance": 3.444
    },
    {
      "task_id": 19,
      "description_ja": "床材のりを塗ったあとにオープンタイムをとる。",
      "execution_rate": 0.691,
      "importance": 3.276
    },
    {
      "task_id": 20,
      "description_ja": "電動ドライバーを使い、石膏ボードを留め付ける。",
      "execution_rate": 0.762,
      "importance": 3.406
    },
    {
      "task_id": 21,
      "description_ja": "床材にあった適切なボンドを選択し、仕入れる。",
      "execution_rate": 0.691,
      "importance": 3.448
    }
  ],
