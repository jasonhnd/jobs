  "tasks_lead_ja": "かん詰食品、びん詰食品、レトルト食品を製造する。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "魚、肉、野菜、果実などの原料を選別する。",
      "execution_rate": 0.524,
      "importance": 3.909
    },
    {
      "task_id": 2,
      "description_ja": "選別した原料を洗浄し、不要な部分の除去やカットをする。",
      "execution_rate": 0.548,
      "importance": 3.913
    },
    {
      "task_id": 3,
      "description_ja": "原料を調理する機械に投入し、調味、加熱などの調理をする。",
      "execution_rate": 0.738,
      "importance": 4.065
    },
    {
      "task_id": 4,
      "description_ja": "分注用の機械で、調理された食品をかん・ビン・レトルトパウチに定量ずつ分注する。",
      "execution_rate": 0.881,
      "importance": 4.081
    },
    {
      "task_id": 5,
      "description_ja": "かんにふたを載せて内部を脱気し、真空巻締機で真空にする。",
      "execution_rate": 0.524,
      "importance": 4.136
    },
    {
      "task_id": 6,
      "description_ja": "かんのふたと胴体の部分を重ねて折り曲げ、二重巻締機で締め付けて密封する。",
      "execution_rate": 0.381,
      "importance": 4.313
    },
    {
      "task_id": 7,
      "description_ja": "キャッパー機で、びんの中に蒸気を吹き付け、びんの上部の空間の空気を脱気し、ふたを取り付けて密封する。",
      "execution_rate": 0.381,
      "importance": 4.188
    },
    {
      "task_id": 8,
      "description_ja": "ヒートシール機でレトルトパウチの口を密閉切断する。",
      "execution_rate": 0.762,
      "importance": 3.875
    },
    {
      "task_id": 9,
      "description_ja": "殺菌釜で内容物が充填されたかん詰に加圧蒸気を送り込んで加熱殺菌する。",
      "execution_rate": 0.571,
      "importance": 4.458
    },
    {
      "task_id": 10,
      "description_ja": "レトルト釜でレトルト食品の加圧殺菌をする。",
      "execution_rate": 0.691,
      "importance": 4.414
    },
    {
      "task_id": 11,
      "description_ja": "製品にシールを貼り、包装する。",
      "execution_rate": 0.738,
      "importance": 4.032
    },
    {
      "task_id": 12,
      "description_ja": "賞味期限などの印字に誤りがないか確認する。",
      "execution_rate": 0.905,
      "importance": 4.342
    },
    {
      "task_id": 13,
      "description_ja": "原料や製品に異常や異物がないか、目視や機械で確認する。",
      "execution_rate": 0.929,
      "importance": 4.359
    },
    {
      "task_id": 14,
      "description_ja": "製造設備の清掃、点検、メンテナンスをする。",
      "execution_rate": 0.952,
      "importance": 4.175
    },
    {
      "task_id": 15,
      "description_ja": "原料や資材を調達し、在庫を管理する。",
      "execution_rate": 0.905,
      "importance": 3.816
    }
  ],
