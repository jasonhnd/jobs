  "tasks_lead_ja": "茶碗や皿などの食器、タイルや洗面台、トイレの便器などの日用品など、陶磁器製品を作る。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "陶土に長石や石英を混ぜ、坏土（はいど）を作る。",
      "execution_rate": 0.625,
      "importance": 3.467
    },
    {
      "task_id": 2,
      "description_ja": "ろくろの中央に坏土の玉を置く。",
      "execution_rate": 0.604,
      "importance": 3.69
    },
    {
      "task_id": 3,
      "description_ja": "モーターや人力でろくろを回転させ、土を成形する。",
      "execution_rate": 0.667,
      "importance": 4.125
    },
    {
      "task_id": 4,
      "description_ja": "坏土の固さの変化を感じながら、ろくろの速度を調節する。",
      "execution_rate": 0.646,
      "importance": 3.806
    },
    {
      "task_id": 5,
      "description_ja": "ゴムのへらおよび湿ったスポンジを使用して、完成品の表面を滑らかにする。",
      "execution_rate": 0.729,
      "importance": 3.057
    },
    {
      "task_id": 6,
      "description_ja": "製品の土台とろくろの間にワイヤーを通して、成形した作品を分離する。",
      "execution_rate": 0.646,
      "importance": 3.839
    },
    {
      "task_id": 7,
      "description_ja": "カリパスと型板を使用して、サイズと形状を確認する。",
      "execution_rate": 0.625,
      "importance": 3.033
    },
    {
      "task_id": 8,
      "description_ja": "乾燥させた後、素焼きする。",
      "execution_rate": 0.875,
      "importance": 3.738
    },
    {
      "task_id": 9,
      "description_ja": "焼成後、表面に飛び出た部分や口台を、サンドペーパーなどで研磨して滑らかにする。",
      "execution_rate": 0.792,
      "importance": 3.105
    },
    {
      "task_id": 10,
      "description_ja": "灰などを混ぜ合わせたりして、ゆう薬を調合する。",
      "execution_rate": 0.667,
      "importance": 3.938
    },
    {
      "task_id": 11,
      "description_ja": "素焼きした素地に、ゆう薬をかけ、高温で焼き上げる。",
      "execution_rate": 0.833,
      "importance": 4.05
    },
    {
      "task_id": 12,
      "description_ja": "高温で焼き上げた陶磁器の上に上絵の具で彩色し、低温で焼き上げる。",
      "execution_rate": 0.5,
      "importance": 3.5
    },
    {
      "task_id": 13,
      "description_ja": "製品に不具合がないか、目視や機械で確認し、異常があるものを選別する。",
      "execution_rate": 0.938,
      "importance": 4.022
    },
    {
      "task_id": 14,
      "description_ja": "完成した製品を包装・梱包し、出荷する。",
      "execution_rate": 0.938,
      "importance": 3.822
    },
    {
      "task_id": 15,
      "description_ja": "石膏で型を作る。",
      "execution_rate": 0.688,
      "importance": 3.091
    },
    {
      "task_id": 16,
      "description_ja": "製造機械を点検、整備する。",
      "execution_rate": 0.958,
      "importance": 3.522
    },
    {
      "task_id": 17,
      "description_ja": "故障した製造機械を修理する。",
      "execution_rate": 0.854,
      "importance": 3.634
    },
    {
      "task_id": 18,
      "description_ja": "原材料を購入し、管理する。",
      "execution_rate": 0.938,
      "importance": 3.689
    },
    {
      "task_id": 19,
      "description_ja": "新しい製品を企画し、開発する。",
      "execution_rate": 0.896,
      "importance": 3.814
    },
    {
      "task_id": 20,
      "description_ja": "製品のデザインを考案する。",
      "execution_rate": 0.833,
      "importance": 3.725
    },
    {
      "task_id": 21,
