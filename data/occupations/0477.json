      "importance": 4.378
    },
    {
      "task_id": 5,
      "description_ja": "指定された場所に向かい、貨物を荷台に積み込む。",
      "execution_rate": 0.94,
      "importance": 4.191
    },
    {
      "task_id": 6,
      "description_ja": "積み込み後に荷締めをする。",
      "execution_rate": 0.9,
      "importance": 4.267
    },
    {
      "task_id": 7,
      "description_ja": "トラックを運転して目的地まで輸送する。",
      "execution_rate": 0.98,
      "importance": 4.449
    },
