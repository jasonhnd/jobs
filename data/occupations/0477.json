      "importance": 3.525
    },
    {
      "task_id": 2,
      "description_ja": "車両の運行前点検をする。",
      "execution_rate": 0.9,
      "importance": 3.756
    },
    {
      "task_id": 3,
      "description_ja": "輸送する貨物の伝票を受け取り、積荷の内容や目的地を確認する。",
