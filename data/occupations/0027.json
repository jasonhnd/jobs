  "tasks_lead_ja": "鉄筋コンクリートの鋳型の役割を果たす型枠を作り、工事現場で組立てる。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "設計図を読み取り、作業で必要となる型枠の形や寸法を書き込んだ加工図を作成する。",
      "execution_rate": 0.909,
      "importance": 4.133
    },
    {
      "task_id": 2,
      "description_ja": "型枠を設置する位置を決めて印をつける。",
      "execution_rate": 0.97,
      "importance": 3.938
    },
    {
      "task_id": 3,
      "description_ja": "加工図に従い、金属製パイプで型枠を支持・固定する枠組みをつくる。",
      "execution_rate": 0.939,
      "importance": 4.0
    },
    {
      "task_id": 4,
      "description_ja": "型枠を組み立て、鎖や器具を用いて鉄製パイプに固定する。",
      "execution_rate": 0.97,
      "importance": 4.0
    },
    {
      "task_id": 5,
      "description_ja": "下げ振りと水準器を使用して、型枠の垂直・水平の並びを確認する。",
      "execution_rate": 0.97,
      "importance": 4.219
    },
    {
      "task_id": 6,
      "description_ja": "コンクリートを流し込んだ際に破裂しないよう、パイプ締めによる固定を行い、パイプの配置が適正か確認する。",
      "execution_rate": 0.939,
      "importance": 3.839
    },
    {
      "task_id": 7,
      "description_ja": "型枠が倒れないよう、サポートやチェーンを使って固定する。",
      "execution_rate": 0.939,
      "importance": 4.161
    },
    {
      "task_id": 8,
      "description_ja": "型枠の中に空泡ができないように均一にコンクリートを流し込む。",
      "execution_rate": 0.849,
      "importance": 3.5
    },
    {
      "task_id": 9,
      "description_ja": "生コン打設の時に、パンクしないよう合番（相番）する。",
      "execution_rate": 0.909,
      "importance": 4.033
    },
    {
      "task_id": 10,
      "description_ja": "コンクリートが固まってから型枠を取り外し、洗浄する。",
      "execution_rate": 0.879,
      "importance": 2.862
    },
    {
      "task_id": 11,
      "description_ja": "コンクリートを打設した後、通り直しの水平を確認する。",
      "execution_rate": 0.909,
      "importance": 4.133
    }
  ],
