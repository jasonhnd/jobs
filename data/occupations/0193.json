  "tasks_lead_ja": "列車に乗務し、発進・停止の信号確認、旅客に対する乗降の案内、誘導、検札などの業務をする。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "運行前に各車両を巡回し、座席や寝台の整備の確認や制御系統や電気系統などの装置の作動状況の点検をする。",
      "execution_rate": 0.733,
      "importance": 3.697
    },
    {
      "task_id": 2,
      "description_ja": "業務の前後に点呼を取る。",
      "execution_rate": 1.0,
      "importance": 3.844
    },
    {
      "task_id": 3,
      "description_ja": "停車駅では、所定の位置に停車したか確認して扉を開く。",
      "execution_rate": 1.0,
      "importance": 4.711
    },
    {
      "task_id": 4,
      "description_ja": "乗客の乗車や降車の完了を確認し、扉を閉める。",
      "execution_rate": 1.0,
      "importance": 4.8
    },
    {
      "task_id": 5,
      "description_ja": "駅係員の出発合図を確認し、運転手に連絡する。",
      "execution_rate": 0.933,
      "importance": 4.452
    },
    {
      "task_id": 6,
      "description_ja": "乗客に対して、停車駅、到着時刻、乗り換えの案内などをアナウンスする。",
      "execution_rate": 1.0,
      "importance": 3.778
    },
    {
      "task_id": 7,
      "description_ja": "指定席の座席への案内や乗車券の検札をする。",
      "execution_rate": 0.733,
      "importance": 3.333
    },
    {
      "task_id": 8,
      "description_ja": "車内巡回しながら精算業務や乗車券の発売をする。",
      "execution_rate": 0.756,
      "importance": 3.059
    },
    {
      "task_id": 9,
      "description_ja": "車内の照明、換気、冷暖房装置などの調節をする。",
      "execution_rate": 0.956,
      "importance": 3.767
    },
    {
      "task_id": 10,
      "description_ja": "駅を通過する際、窓からホームの様子を見て、安全を確認する。",
      "execution_rate": 0.889,
      "importance": 3.85
    },
    {
      "task_id": 11,
      "description_ja": "運行中に線路内の状況を確認する。",
      "execution_rate": 0.778,
      "importance": 3.514
    },
    {
      "task_id": 12,
      "description_ja": "各駅の到着、発車、通過の遅延時刻を記録する。",
      "execution_rate": 0.667,
      "importance": 2.8
    },
    {
      "task_id": 13,
      "description_ja": "身障者の乗降の補助をする。",
      "execution_rate": 0.8,
      "importance": 3.583
    },
    {
      "task_id": 14,
      "description_ja": "車内で事故やトラブルが発生した場合には、迅速かつ適切に処理し、車内の秩序を維持する。",
      "execution_rate": 1.0,
      "importance": 4.511
    },
    {
      "task_id": 15,
      "description_ja": "列車事故や災害などの場合は乗客を避難誘導し安全を確保する。",
      "execution_rate": 1.0,
      "importance": 4.733
    },
    {
      "task_id": 16,
      "description_ja": "事故が発生した場合は、運転士と連携し列車防護を行う。",
      "execution_rate": 1.0,
      "importance": 4.644
    },
    {
      "task_id": 17,
      "description_ja": "ホーム上に危険があれば、非常停止手配を行う。",
      "execution_rate": 1.0,
      "importance": 4.822
    },
    {
      "task_id": 18,
      "description_ja": "運転整理について乗務員に適切な指示をする。",
      "execution_rate": 0.644,
      "importance": 3.414
    },
    {
      "task_id": 19,
      "description_ja": "ホームや駅、線路上で問題が発生した場合は手笛を吹く。",
      "execution_rate": 0.6,
      "importance": 2.963
    },
    {
      "task_id": 20,
      "description_ja": "列車内の遺失物を駅員に届ける。",
      "execution_rate": 1.0,
      "importance": 3.511
    },
    {
      "task_id": 21,
      "description_ja": "終着駅で車内を見回り、異常がないか確認する。",
      "execution_rate": 0.911,
      "importance": 3.195
    },
    {
      "task_id": 22,
      "description_ja": "車内を清掃・消毒する。",
      "execution_rate": 0.822,
      "importance": 2.676
    },
    {
      "task_id": 23,
      "description_ja": "入替合図を受け、車両の連結・開放・移動を行う。",
      "execution_rate": 0.711,
      "importance": 4.031
    },
    {
      "task_id": 24,
      "description_ja": "乗務終了後は車掌区に戻り、必要事項を日誌に記録して報告する。",
      "execution_rate": 0.8,
      "importance": 3.75
    },
    {
      "task_id": 25,
      "description_ja": "降雪時には着雪点検を行う。",
      "execution_rate": 0.622,
      "importance": 2.857
    },
    {
      "task_id": 26,
      "description_ja": "無人駅で乗降する客の乗車料金を精算する。",
      "execution_rate": 0.467,
