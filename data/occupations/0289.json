  "tasks_lead_ja": "皮革靴のデザイン、設計、パーツの型づくり、皮革の裁断、縫製、釣り込み・底付け、仕上げ、の作業を行う。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "靴のデザイン・設計をする。",
      "execution_rate": 0.818,
      "importance": 4.111
    },
    {
      "task_id": 2,
      "description_ja": "靴型の甲部に紙やテープ紙を張り、それを展開して甲部パーツの型を作る。",
      "execution_rate": 0.864,
      "importance": 3.895
    },
    {
      "task_id": 3,
      "description_ja": "靴に使用する皮革を選択する。",
      "execution_rate": 0.818,
      "importance": 3.389
    },
    {
      "task_id": 4,
      "description_ja": "油圧式裁断機を使って型どおりに皮革を裁断する。",
      "execution_rate": 0.773,
      "importance": 3.529
    },
    {
      "task_id": 5,
      "description_ja": "裁断されたパーツのふちをすいたり折り曲げたりした後、縫い目、端、印にそって針の下に置く。",
      "execution_rate": 0.864,
      "importance": 3.684
    },
    {
      "task_id": 6,
      "description_ja": "縫製機械を使用するための準備やセッティングを行う。",
      "execution_rate": 0.818,
      "importance": 3.778
    },
    {
      "task_id": 7,
      "description_ja": "押さえやローラーで皮の部品を固定し、手、足、ひざで操作する制御装置を使用して機械縫製をする。",
      "execution_rate": 0.773,
      "importance": 3.824
    },
    {
      "task_id": 8,
      "description_ja": "靴に装飾的な部品を縫い付けるために縫製機械を操作する。",
      "execution_rate": 0.818,
      "importance": 3.556
    },
    {
      "task_id": 9,
      "description_ja": "釣込機で甲部を靴型に密着させ、底材料を接着剤で貼り付けるか、ミシンで縫いつける。",
      "execution_rate": 0.727,
      "importance": 3.813
    },
    {
      "task_id": 10,
      "description_ja": "甲部を機械釣りして、電気釜に入れる。",
      "execution_rate": 0.727,
      "importance": 3.125
    },
    {
      "task_id": 11,
      "description_ja": "圧着をした靴から型を抜き、熱風やコテで仕上げ作業をする。",
      "execution_rate": 0.864,
      "importance": 3.474
    },
    {
      "task_id": 12,
      "description_ja": "コテやアイロンを使って、靴のしわを取る。",
      "execution_rate": 0.818,
      "importance": 3.222
    },
    {
      "task_id": 13,
      "description_ja": "はさみやナイフを使用して、靴の部品から余計な糸や材料を切り取る。",
      "execution_rate": 0.955,
      "importance": 3.238
    },
    {
      "task_id": 14,
      "description_ja": "靴底やかかとの不要な部分を機械で削り、仕上剤で化粧をする。",
      "execution_rate": 0.864,
      "importance": 3.579
    },
    {
      "task_id": 15,
      "description_ja": "バフを使って靴の表面を起毛する。",
      "execution_rate": 0.773,
      "importance": 3.118
    },
    {
      "task_id": 16,
      "description_ja": "生産過程で靴に付いた汚れ等をとる。",
      "execution_rate": 0.909,
      "importance": 3.7
    },
    {
      "task_id": 17,
      "description_ja": "塗料やクリ－ムを使用して、革の艶や色感を表現する。",
      "execution_rate": 0.864,
      "importance": 2.947
    },
    {
      "task_id": 18,
      "description_ja": "靴に中敷きを入れる。",
      "execution_rate": 0.955,
      "importance": 3.429
    },
    {
      "task_id": 19,
      "description_ja": "靴を接着、縫製、補強する自動装置の運転を監視する。",
      "execution_rate": 0.727,
      "importance": 3.563
    },
    {
      "task_id": 20,
      "description_ja": "仕様書への適合性を確認するために、靴の部品を取り外し、部品とデザインを調べる。",
      "execution_rate": 0.818,
      "importance": 3.5
    },
    {
      "task_id": 21,
      "description_ja": "完成した靴を検品する。",
      "execution_rate": 0.864,
      "importance": 3.632
    },
    {
      "task_id": 22,
      "description_ja": "お客から預かった靴を修理する。",
      "execution_rate": 0.773,
      "importance": 3.059
    },
    {
      "task_id": 23,
