  "tasks": [
    {
      "task_id": 1,
      "description_ja": "設計図に基づいて使用する鉄筋の直径や長さ、本数などを書き込んだ加工帳を作成する。",
      "execution_rate": 0.857,
      "importance": 4.278
    },
    {
      "task_id": 2,
      "description_ja": "鉄筋を指定の長さに切断するため、金のこ、バー・カッター、アセチレン・トーチを操作する。",
      "execution_rate": 0.905,
      "importance": 3.895
    },
    {
      "task_id": 3,
      "description_ja": "鉄筋を曲げるため、ロッド曲げ機を操作する。",
      "execution_rate": 0.905,
      "importance": 3.789
    },
    {
      "task_id": 4,
      "description_ja": "溶接装置を使用して、鉄筋を溶接する。",
      "execution_rate": 0.524,
      "importance": 3.636
    },
    {
      "task_id": 5,
      "description_ja": "加工した鉄筋を工事現場に搬入するため、クレーンや重機を操作する。",
      "execution_rate": 0.762,
      "importance": 3.688
    },
    {
      "task_id": 6,
      "description_ja": "設計図に従って鉄筋を組立て、結束線とペンチを使用して固定する。",
      "execution_rate": 0.857,
      "importance": 4.056
    },
    {
      "task_id": 7,
      "description_ja": "鉄筋に錆び止めスプレーをかける",
      "execution_rate": 0.714,
      "importance": 2.6
    }
