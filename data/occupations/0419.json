  "tasks_lead_ja": "化粧品などに使用される香料や、食品に使用される食品香料を調合する。",
  "tasks": [
    {
      "task_id": 1,
      "description_ja": "依頼主と打ち合わせを行い、消費者の好みなどを考えて、条件に適合した香りのイメージをつくる。",
      "execution_rate": 1.0,
      "importance": 4.75
    },
    {
      "task_id": 2,
      "description_ja": "香料の中から使用する原料を選定して調合割合を決め、処方せんを作成する。",
      "execution_rate": 1.0,
      "importance": 4.972
    },
    {
      "task_id": 3,
      "description_ja": "処方せんに従って、においを確認しながら精密天秤で香料を秤量して調合し、見本をつくる。",
      "execution_rate": 0.944,
      "importance": 4.412
    },
    {
      "task_id": 4,
      "description_ja": "見本をテストにかけて、においの強さや良し悪しを評価する。",
      "execution_rate": 0.972,
      "importance": 4.743
    },
    {
      "task_id": 5,
      "description_ja": "香料見本を製作し、製品の開発工程に提示する。",
      "execution_rate": 0.944,
      "importance": 4.206
    },
    {
      "task_id": 6,
      "description_ja": "調合を修正し、処方せんを完成させる。",
      "execution_rate": 1.0,
      "importance": 4.639
    },
    {
      "task_id": 7,
      "description_ja": "完成した香料を化粧品や食品に添加して、試用や試食を行い、効果を確認する。",
      "execution_rate": 1.0,
      "importance": 4.861
    },
    {
      "task_id": 8,
      "description_ja": "香料原料を加えた原液をスプレードライし、粉末香料を製造する。",
      "execution_rate": 0.722,
      "importance": 3.269
    },
    {
      "task_id": 9,
      "description_ja": "分析器を使い、香料を分析する。",
      "execution_rate": 0.889,
      "importance": 3.906
    }
  ],
