# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env
.env.*
!.env.example

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
# dist/ IS tracked per DATA_ARCHITECTURE.md D-009 (Vercel has no Python build server,
# so projections are built locally and committed). dist.next/ + dist.prev/ are atomic
# staging dirs and must NOT be committed.
# After Track D · PR 35 (see docs/MIGRATION_PLAN.md), dist/ will be gitignored too.
dist.next/
dist.prev/
build/
.cache/

# Astro / TS migration (see docs/MIGRATION_PLAN.md)
# Astro build output (Vercel deploy target — built fresh in CI, not committed).
dist-astro/
# Temporary TS-ETL output dir during Track B; used for byte-diff vs Python ETL.
dist-ts/
# Atomic-stage dirs from Python build attempts (left over when swap fails on Dropbox lock).
dist-py.next/
# Astro internal cache (auto-generated types, content collection metadata)
.astro/

# Partial-run manifests — produced by build_occupations.py --ids / --limit
# (smoke tests). Canonical .occ_manifest.json IS tracked; .partial.json is
# local-only debug artifact.
scripts/.occ_manifest.partial.json
scripts/.*.partial.json

# Pipeline raw outputs (kept locally, not pushed)
html/
pages/
raw/
*.log

# uv lock file is tracked; venv and cache are not
.venv/
.uv-cache/

# Local-only dev artifacts (don't ship to public repo)
.claude/
_audit/
.vercel

# Credentials — never commit these (defensive patterns; real credentials should
# live OUTSIDE the repo, e.g. ~/.config/mirai-shigoto/)
*-sa.json
*service-account*.json
*credentials*.json
gcp-*.json

# Personal monitoring/dashboards cheatsheet — local-only operator reference,
# contains direct dashboard URLs and account-specific paths. Not source code.
analytics/dashboards.md

# Local-only preview / scratch HTML files. Names starting with `_` are draft.
_*.html

# docs/ — all design / planning markdown is local-only, not synced to GitHub.
docs/
