  "about.title":             { "ja": "この企画について",             "en": "About this project" },
  "about.intro":             { "ja": "「未来の仕事」は、552 の日本の職業を AI 影響度・人口・年収・働き方の 5 次元プロファイルで多角的に可視化した、独立系の分析プロジェクトです。", "en": "Mirai-no-Shigoto visualizes 552 Japanese occupations across AI exposure, workforce, salary, and a 5-axis profile. Independent project, not affiliated with any government agency." },
  "about.method.title":      { "ja": "方法論",                       "en": "Methodology" },
  "about.method.ai_score.title":   { "ja": "AI影響スコア",           "en": "AI exposure score" },
  "about.method.ai_score.body":    { "ja": "Anthropic Claude モデルが、各職業の主要タスクを評価し、0-10 のスケールで AI 代替リスクを推定。", "en": "An Anthropic Claude model evaluates each occupation's primary tasks and estimates AI substitution risk on a 0–10 scale." },
  "about.method.workers.title":    { "ja": "就業者数・年収",         "en": "Workforce & salary" },
  "about.method.workers.body":     { "ja": "厚生労働省「職業情報提供サイト（jobtag）」より採取（2026 年 4 月時点）。", "en": "Sourced from MHLW's Job Information Site (jobtag), April 2026 snapshot." },
  "about.method.demand.title":     { "ja": "有効求人倍率",           "en": "Demand ratio" },
  "about.method.demand.body":      { "ja": "労働市場における供給と需要の比。1.0 を上回ると人手不足。", "en": "Ratio of openings to applicants. Above 1.0 = labor shortage." },
  "about.method.profile.title":    { "ja": "5次元プロファイル",      "en": "5-axis profile" },
  "about.method.profile.body":     { "ja": "IPD データの 50+ 細目を「創造性 / 対人 / 判断 / 体力 / 反復性」の 5 軸に集約。", "en": "We aggregate 50+ IPD subdimensions into 5 axes: Creativity / Interpersonal / Judgment / Physical / Routine." },
  "about.sources.title":     { "ja": "データ出典",                   "en": "Data sources" },
  "about.sources.list.mhlw": { "ja": "厚労省「職業情報提供サイト（jobtag）」", "en": "MHLW Job Information Site (jobtag)" },
  "about.sources.list.oecd": { "ja": "OECD「Future of Work」",       "en": "OECD Future of Work" },
  "about.sources.list.census":{"ja": "総務省「国勢調査」",           "en": "Statistics Bureau, National Census" },
  "about.caveats.title":     { "ja": "注意点",                       "en": "Caveats" },
  "about.caveats.body":      { "ja": "AI 影響スコアは推定値であり、確定的な予測ではありません。実際の雇用変化は、技術発展速度・規制・社会受容性など複合要因で決まります。", "en": "AI exposure scores are estimates, not deterministic forecasts. Actual employment shifts depend on technology pace, regulation, and social acceptance." },
