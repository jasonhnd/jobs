{"id":17,"title_ja":"陶磁器製造","tasks_lead_ja":"茶碗や皿などの食器、タイルや洗面台、トイレの便器などの日用品など、陶磁器製品を作る。","tasks":[{"task_id":1,"description_ja":"陶土に長石や石英を混ぜ、坏土（はいど）を作る。","execution_rate":0.625,"importance":3.467,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":2,"description_ja":"ろくろの中央に坏土の玉を置く。","execution_rate":0.604,"importance":3.69,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":3,"description_ja":"モーターや人力でろくろを回転させ、土を成形する。","execution_rate":0.667,"importance":4.125,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":4,"description_ja":"坏土の固さの変化を感じながら、ろくろの速度を調節する。","execution_rate":0.646,"importance":3.806,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":5,"description_ja":"ゴムのへらおよび湿ったスポンジを使用して、完成品の表面を滑らかにする。","execution_rate":0.729,"importance":3.057,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":6,"description_ja":"製品の土台とろくろの間にワイヤーを通して、成形した作品を分離する。","execution_rate":0.646,"importance":3.839,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":7,"description_ja":"カリパスと型板を使用して、サイズと形状を確認する。","execution_rate":0.625,"importance":3.033,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":8,"description_ja":"乾燥させた後、素焼きする。","execution_rate":0.875,"importance":3.738,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":9,"description_ja":"焼成後、表面に飛び出た部分や口台を、サンドペーパーなどで研磨して滑らかにする。","execution_rate":0.792,"importance":3.105,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":10,"description_ja":"灰などを混ぜ合わせたりして、ゆう薬を調合する。","execution_rate":0.667,"importance":3.938,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":11,"description_ja":"素焼きした素地に、ゆう薬をかけ、高温で焼き上げる。","execution_rate":0.833,"importance":4.05,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at