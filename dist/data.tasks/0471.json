{"id":471,"title_ja":"M&Aマネージャー、M&Aコンサルタント/M&Aアドバイザー","tasks_lead_ja":"Ｍ＆Ａ（Mergers and Acquisitions：企業合併・事業買収）がその目的を達成するよう、法律、財務などの専門スキルを活用して、対象企業・事業の選定から、交渉、契約締結に至るまでのプロセスを適切に進捗管理する。","tasks":[{"task_id":1,"description_ja":"プロジェクトの進捗を管理する。","execution_rate":0.939,"importance":3.645,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":2,"description_ja":"経営企画部などが行う経営戦略・M&A戦略策定を支援する。","execution_rate":0.909,"importance":3.3,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":3,"description_ja":"Ｍ＆Ａを検討する企業との相談を行う。","execution_rate":0.939,"importance":3.548,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":4,"description_ja":"Ｍ＆Ａ戦略に適合する、あるいは相談を踏まえた売り手（または買い手）企業を抽出・評価し、M&A対象企業を絞り込む。","execution_rate":0.939,"importance":3.516,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":5,"description_ja":"投資銀行などから持ち込まれたM&A案件を評価する。","execution_rate":0.909,"importance":2.9,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":6,"description_ja":"絞り込んだM&A対象企業と接触し、M&Aの可能性を協議する。","execution_rate":0.939,"importance":3.355,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":7,"description_ja":"売り手（買い手）とM&A交渉を行い、本格的M&A交渉の開始に合意した場合には基本合意（LOI：Letter of Intent）を締結する。","execution_rate":0.939,"importance":3.645,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":8,"description_ja":"弁護士、公認会計士などの専門家と協力して、M&Aに足る企業かを評価するデューデリジェンス（DD：Due Diligence）を行う。","execution_rate":0.939,"importance":3.516,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":9,"description_ja":"DDの結果を踏まえ、買収価額算定のための評価を行う。","execution_rate":0.939,"importance":3.548,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":10,"description_ja":"M&Aのための資金調達を行う（金融機関との交渉）。","execution_rate":0.879,"importance":3.207,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":11,"description_ja":"DDと買収価額算定評価に基づき買収価額を協議し、合意に達すれば売買契約を締結する。","execution_rate":0.939,"importance":3.71,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":12,"description_ja":"M&Aに係る広報を行う（PR、IR）。","execution_rate":0.909,"importance":2.867,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":13,"description_ja":"所有権移転、対価支払い、合併などの諸手続きを行う。","execution_rate":0.909,"importance":3.267,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":14,"description_ja":"M&Aの効果の実現を図るための統合プロセス（PMI：Post Merger Integration）を実施する。具体的には、人材（社長・CFO等）の採用・確保など。","execution_rate":0.939,"importance":3.452,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":15,"description_ja":"節目節目に社内（経営企画部など）にM&A交渉状況を報告し、必要な指示を仰ぐ。","execution_rate":0.939,"importance":3.484,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null},{"task_id":16,"description_ja":"節目節目で必要な資料を作成する。","execution_rate":0.939,"importance":3.387,"ai_risk":null,"ai_rationale_ja":null,"scored_by":null,"scored_at":null}]}
