{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "trailingSlash": false,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=(), payment=(), usb=()" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/data.treemap.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }
      ]
    },
    {
      "source": "/data.search.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }
      ]
    },
    {
      "source": "/data.detail/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }
      ]
    },
    {
      "source": "/data.labels/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=3600" }
      ]
    },
    {
      "source": "/data.sectors.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=3600" }
      ]
    },
    {
      "source": "/og.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" },
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=3600" }
      ]
    },
    {
      "source": "/llms(-full)?\\.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=3600" },
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/styles/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/data.treemap.json", "destination": "/dist/data.treemap.json" },
    { "source": "/data.search.json", "destination": "/dist/data.search.json" },
    { "source": "/data.sectors.json", "destination": "/dist/data.sectors.json" },
    { "source": "/data.profile5.json", "destination": "/dist/data.profile5.json" },
    { "source": "/data.transfer_paths.json", "destination": "/dist/data.transfer_paths.json" },
    { "source": "/data.detail/:file", "destination": "/dist/data.detail/:file" },
    { "source": "/data.labels/:file", "destination": "/dist/data.labels/:file" }
  ],
  "redirects": [
    {
      "source": "/data.json",
      "destination": "/data.treemap.json",
      "permanent": true
    },
    {
      "source": "/occ/:id(\\d+)-:slug*",
      "destination": "/ja/:id",
      "permanent": true
    },
    {
      "source": "/occ/:id(\\d+)",
      "destination": "/ja/:id",
      "permanent": true
    },
    {
      "source": "/en/:path*",
      "destination": "/ja/:path*",
      "permanent": true
    }
  ]
}
