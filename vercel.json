{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": null,
  "trailingSlash": false,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/data.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }
      ]
    },
    {
      "source": "/og.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/occ/:id(\\d+)-:slug*",
      "has": [{ "type": "query", "key": "lang", "value": "en" }],
      "destination": "/en/:id",
      "permanent": true
    },
    {
      "source": "/occ/:id(\\d+)-:slug*",
      "destination": "/ja/:id",
      "permanent": true
    },
    {
      "source": "/occ/:id(\\d+)",
      "has": [{ "type": "query", "key": "lang", "value": "en" }],
      "destination": "/en/:id",
      "permanent": true
    },
    {
      "source": "/occ/:id(\\d+)",
      "destination": "/ja/:id",
      "permanent": true
    }
  ]
}
